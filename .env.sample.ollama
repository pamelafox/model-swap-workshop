# Ollama local setup
# Ollama exposes an OpenAI-compatible API at http://localhost:11434/v1
# Since FOUNDRY_MODELS_ENDPOINT is used directly as the base URL,
# just point it at Ollama's /v1 endpoint.
FOUNDRY_MODELS_ENDPOINT=http://localhost:11434/v1
FOUNDRY_API_KEY=ollama

# For Anthropic-specific examples (rag_messages.py, pydanticai_agent.py with claude):
# Ollama supports the Anthropic Messages API at http://localhost:11434
# Note: citations are NOT supported, so rag_messages.py won't work as-is.
FOUNDRY_ANTHROPIC_MODELS_ENDPOINT=http://localhost:11434
FOUNDRY_ANTHROPIC_API_KEY=ollama

# Example model names to pull:
#   ollama pull qwen3.5:9b
#   ollama pull gemma4:e4b
#   ollama pull llama3.1:8b
#
# Then set MODEL = "llama3.1:8b" (or whichever) in the example scripts. 

# Not applicable for Ollama:
# FOUNDRY_PROJECT_ENDPOINT=
